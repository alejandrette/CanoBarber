---
const { title = "Cano Barber", description = "Barber shop | Cortes y barba con estilo" } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logo_white.png" />
  </head>
  <body class="bg-dark-bg text-bone font-body leading-relaxed m-0 min-h-screen">
    <slot />
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  @theme {
    --color-gold-primary: #C5A059;
    --color-dark-bg: #1A1A1B;
    --color-bone: #F5F5F5;
    --color-dark-accent: #260E01;
    
    --font-titles: "Playfair Display", serif;
    --font-body: "Montserrat", sans-serif;
  }

  @layer components {
    .container-custom {
      @apply w-[min(1100px,92vw)] mx-auto;
    }

    .section-padding {
      @apply py-8 md:py-4; 
    }

    .btn {
      @apply inline-flex items-center justify-center px-4 py-2 rounded-xl transition-all duration-200 font-semibold border border-white/10 bg-white/5 text-bone shadow-lg hover:-translate-y-0.5 hover:bg-white/10;
    }

    .btn-primary {
      @apply bg-gold-primary border-gold-primary text-dark-bg hover:bg-white hover:text-dark-bg;
    }

    .card-custom {
      @apply border border-white/10 bg-white/5 rounded-2xl shadow-2xl p-6;
    }

    /* Reemplazo de la fila de precios con puntitos */
    .price-row {
      @apply flex items-center text-[15px] w-full;
    }
    
    .price-dots {
      @apply flex-1 border-b border-dotted border-white/30 mx-2.5 mb-1;
    }

    .pill-custom {
      @apply inline-block px-3 py-1.5 rounded-full border border-gold-primary/30 bg-gold-primary/10 text-gold-primary text-[13px];
    }
  }

  a { @apply no-underline; color: inherit; }
</style>