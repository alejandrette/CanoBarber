---
const { title = "Cano Barber", description = "Barber shop | Cortes y barba con estilo" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root{
	--offWhite: rgba(255,243,219);
	--brown: rgba(97,33,15);
	--darkBrown: rgba(38, 14, 1);

	--card: #fffdf8;
  --text: var(--darkBrown);
  --muted: rgba(97,33,15,.65);

  --border: rgba(97,33,15,.18);

  --shadow: 0 12px 30px rgba(38,14,1,.12);
  }

  *{ box-sizing:border-box; }

  body{
	margin:0;
	font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
	background: linear-gradient(
    180deg,
    var(--brown) 0%,
    #f7e7d6 100%
  );
	color: var(--text);
	line-height: 1.5;
  }

  a{ color: inherit; text-decoration:none; }

  .container{ width:min(1100px, 92vw); margin:0 auto; }

  section{ padding: 32px 0; }
  @media (max-width: 900px){
    section { padding: 16px 0; }
  }

  .dots{
    flex: 1;
    border-bottom: 1px dotted #aaaab1;
    margin: 0 10px;
  }

   .fila{
    display: flex;
    align-items: center;
    font-size: 15px;
  }

  .fila span:first-child{
    white-space: nowrap;
  }
  
 .btn{
	display:inline-flex;
	align-items:center;
	justify-content:center;
	padding: 8px 12px;
	border-radius: 14px;
	transition: all .2s ease;
	font-weight: 600;border: 1px solid var(--border);
  background: var(--card);
  color: var(--darkBrown);
  box-shadow: 0 6px 16px rgba(38,14,1,.08);
  }

.btn:hover{
  background: rgba(97,33,15,.06);
  transform: translateY(-2px);
}

.btn.primary{
  background: var(--brown);
  border-color: var(--brown);
  color: var(--offWhite);
}

.btn.primary:hover{
  background: var(--darkBrown);
}

  .pill{
    display:inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid rgba(97,33,15,.25);
    background: rgba(97,33,15,.08);
    color: var(--brown);
    font-size: 13px;
  }

  section{ padding: 32px 0; }
  
  .card{
    border: 1px solid var(--border);
    background: var(--card);
    border-radius: 18px;
    box-shadow: var(--shadow);
  }
  .grid{ display:grid; gap: 16px; }
  .muted{ color: var(--muted); }
  .h2{ font-size: clamp(22px, 2.2vw, 30px); margin: 0 0 8px; }
  .lead{ font-size: 16px; color: var(--muted); margin: 0; }
  .divider{ height:1px; background: rgba(97,33,15,.15); margin: 18px 0; }

  @media (max-width: 900px){
    section { padding: 16px 0; }
  }
</style>