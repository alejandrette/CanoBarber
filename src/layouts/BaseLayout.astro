---
const { title = "Cano Barber", description = "Barber shop | Cortes y barba con estilo" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root{
	--bg: #fdfdfd;
	--card: #ffffff;
	--text: #1e1e2a;
	--muted: #7a7a8c;

	--brand: #d6b3ff;
	--brand-soft: #f3e8ff;
	
	--border: #ececf3;
	--shadow: 0 10px 25px rgba(0,0,0,.05);
  }

  *{ box-sizing:border-box; }

  body{
	margin:0;
	font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
	background: linear-gradient(180deg, #ffffff 0%, #faf9ff 100%);
	color: var(--text);
	line-height: 1.5;
  }

  a{ color: inherit; text-decoration:none; }

  .container{ width:min(1100px, 92vw); margin:0 auto; }

  section{ padding: 32px 0; }
  @media (max-width: 900px){
    section { padding: 16px 0; }
  }

  .dots{
    flex: 1;
    border-bottom: 1px dotted #aaaab1;
    margin: 0 10px;
  }

   .fila{
    display: flex;
    align-items: center;
    font-size: 15px;
  }

  .fila span:first-child{
    white-space: nowrap;
  }

  /* HOME-only: Precios estilo "menú" */
  .precios-title{
    text-align: center;
    margin-bottom: 26px;
  }

  .precios-grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 34px;
    padding: 26px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: #faf9ff;
  }

  .precios-col{
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .precio-item h3{
    margin: 0;
    font-size: 16px;
    font-weight: 800;
  }

  .precio-item p{
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .precio-top{
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .precio-top strong{
    font-weight: 900;
    font-size: 16px;
    color: var(--text);
    white-space: nowrap;
  }

  .precio-dots{
    flex: 1;
    border-bottom: 1px dotted rgba(255,255,255,.28);
    transform: translateY(-2px);
    min-width: 20px;
  }
  
  .btn{
	display:inline-flex;
	align-items:center;
	justify-content:center;
	padding: 12px 16px;
	border-radius: 14px;
	border: 1px solid var(--border);
	background: #ffffff;
	box-shadow: var(--shadow);
	transition: all .2s ease;
	font-weight: 600;
	color: var(--text);
  }

.btn:hover{
  transform: translateY(-2px);
  background: var(--brand-soft);
}

.btn.primary{
  background: var(--brand);
  color: #ffffff;
  border-color: var(--brand);
}
  .pill{
  display:inline-block;
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  color: var(--muted);
  background: #f8f7ff;
  font-size: 13px;
}

  section{ padding: 32px 0; }
  .card{
  border: 1px solid var(--border);
  background: var(--card);
  border-radius: 18px;
  box-shadow: var(--shadow);
}
  .grid{ display:grid; gap: 16px; }
  .muted{ color: var(--muted); }
  .h2{ font-size: clamp(22px, 2.2vw, 30px); margin: 0 0 8px; }
  .lead{ font-size: 16px; color: var(--muted); margin: 0; }
  .divider{ height:1px; background: var(--border); margin: 18px 0; }

  @media (max-width: 900px){
    section { padding: 16px 0; }
  }
</style>