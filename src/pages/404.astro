---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Corte no encontrado | Cano Barber">
  <main class="min-h-[80vh] flex items-center justify-center section-padding">
    <div class="container-custom text-center">
      <h1 class="text-9xl font-titles text-gold-primary opacity-20 absolute inset-0 flex items-center justify-center -z-10 select-none">
        404
      </h1>
      
      <div class="relative z-10">
        <h2 class="text-4xl md:text-6xl mb-6">¡Vaya trasquilón!</h2>
        
        <p class="text-gray-400 text-lg mb-10 max-w-md mx-auto">
          Parece que la página que buscas se ha ido por el sumidero. No te preocupes, aún podemos arreglar tu barba.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="/" class="btn btn-primary">
            Volver al inicio
          </a>
          <a href="/#contacto" class="btn border-white/10 hover:border-gold-primary">
            Reservar cita
          </a>
        </div>
      </div>
      
      <div class="mt-16 opacity-30">
        <img src="/logo_black.png" alt="Cano Barber" class="w-16 mx-auto brightness-0 invert" />
      </div>
    </div>
  </main>
</BaseLayout>