---
const precios = [
  { nombre: "Corte de pelo", precio: "10€", descripcion: "Plasmamos con precisión la idea del estilo que deseas obtener, utilizando las técnicas y herramientas necesarias." },
  { nombre: "Corte y barba", precio: "12€", descripcion: "Corte de pelo combinado con arreglo y perfilado de barba para conseguir un look completo y equilibrado." },
  { nombre: "Arreglo barba", precio: "4€", descripcion: "Perfilado y arreglo de barba adaptado a tu estilo, cuidando cada detalle para un acabado limpio." },
  { nombre: "Cejas", precio: "2€", descripcion: "Diseño y perfilado de cejas, limpieza y definición." },
  { nombre: "Mechas", precio: "desde 15€", descripcion: "Aplicación de mechas para aportar luz, contraste y estilo al pelo." },
  { nombre: "Decoloración", precio: "desde 25€", descripcion: "Proceso de decoloración profesional para preparar el pelo antes de aplicar color o mechas." },
  { nombre: "Lavado", precio: "2€", descripcion: "Lavado de pelo con productos profesionales para limpiar y preparar el pelo antes o después del servicio." }
];
---

<section id="precios" class="section-padding">
  <div class="container-custom">
    <div class="card-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl mb-2">Listado de Precios</h2>
        <div class="w-24 h-1 bg-gold-primary mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-10">
        {precios.map((servicio) => (
          <article class="group">
            <div class="price-row mb-2">
              <h3 class="font-bold text-lg tracking-wide group-hover:text-gold-primary transition-colors">
                {servicio.nombre}
              </h3>
              <span class="price-dots opacity-30"></span>
              <strong class="text-gold-primary text-lg font-black italic">
                {servicio.precio}
              </strong>
            </div>

            <p class="text-sm text-gray-400 leading-relaxed max-w-prose">
              {servicio.descripcion}
            </p>
          </article>
        ))}
      </div>

      <div class="mt-12 pt-8 border-t border-white/5 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-gray-500">
          Precios sujetos a variaciones según el trabajo realizado
        </p>
      </div>
    </div>
  </div>
</section>