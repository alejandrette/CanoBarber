---
const links = [
  { href: "#precios", label: "Precios" },
  { href: "#galeria", label: "Galería" },
  { href: "#contacto", label: "Contacto" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="#" class="brand">
      <img class="brand-logo" src="/logo_black.png" alt="Logo Cano Barber" />
      <span class="brand-name">Cano Barber</span>
      <span class="pill brand-tag">Don Benito</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav nav-desktop" aria-label="Navegación principal">
      {links.map((l) => (
        <a href={l.href} class="pill nav-link">{l.label}</a>
      ))}
      <a class="btn primary nav-cta" href="#contacto">Reservar</a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      class="burger"
      type="button"
      aria-label="Abrir menú"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="burger-lines" aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile menu (overlay) -->
<div id="mobile-menu" class="mobile-menu" data-open="false" aria-hidden="true">
  <button class="mobile-backdrop" type="button" aria-label="Cerrar menú"></button>

  <div class="mobile-panel">
    {links.map((l) => (
      <a href={l.href} class="mobile-link">{l.label}</a>
    ))}
    <a class="mobile-link mobile-link--cta" style="display: none;" href="#contacto">Reservar</a>
  </div>
</div>
</header>

<script>
  const header = document.querySelector(".site-header");
  const btn = header?.querySelector(".burger");
  const menu = header?.querySelector("#mobile-menu");
  const backdrop = header?.querySelector(".mobile-backdrop");

  backdrop?.addEventListener("click", () => setOpen(false));

  function setOpen(open: boolean) {
    if (!btn || !menu) return;
    btn.setAttribute("aria-expanded", String(open));
    menu.setAttribute("data-open", String(open));
    menu.setAttribute("aria-hidden", String(!open));
  }

  btn?.addEventListener("click", () => {
    const open = btn.getAttribute("aria-expanded") === "true";
    setOpen(!open);
  });

  // Cerrar al hacer click en un link
  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => setOpen(false));
  });
</script>

<style>
  /* Header base */
  .site-header{
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--offWhite);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--brown);
  }

  .header-inner{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    gap: 16px;
  }

  .brand{
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: .2px;
  }

  .brand-logo{
    width: 48px;
    height: 32px;
    object-fit: contain;
    display: block;
  }

  .brand-tag{ margin-left: 8px; }

  .nav-cta{ 
    display: none; 
  }

  /* Desktop nav */
  .nav{
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-link{ border-radius: 12px; }

  /* Burger (hidden on desktop) */
  .burger{
    display: none;
    border: 1px solid var(--border);
    background: var(--offWhite);
    box-shadow: var(--shadow);
    border-radius: 14px;
    width: 44px;
    height: 44px;
    padding: 0;
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }

  .burger-lines{
    width: 18px;
    height: 2px;
    background: var(--text);
    display: block;
    position: relative;
    border-radius: 999px;
  }
  .burger-lines::before,
  .burger-lines::after{
    content:"";
    position: absolute;
    left: 0;
    width: 18px;
    height: 2px;
    background: var(--text);
    border-radius: 999px;
  }
  .burger-lines::before{ top: -6px; }
  .burger-lines::after{ top: 6px; }

  .mobile-menu{
    position: fixed;
    left: 0;
    right: 0;
    top: 76px;
    z-index: 60;
    display: none;
  }

  .mobile-menu[data-open="true"]{
    display: block;
  }
  
  .mobile-backdrop{
    position: fixed;
    left: 0;
    right: 0;
    top: 76px;
    bottom: 0;
  
    background: transparent;
    border: 0;
    padding: 0;
    display: none;
  }
  
  .mobile-menu[data-open="true"] .mobile-backdrop{
  display: block;
  }
  
  .mobile-panel{
    margin: 10px 16px 16px;
    padding: 16px 20px;
    position: relative;
    z-index: 1;
  
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  
    background: rgba(255,243,219,.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  
  .mobile-link{
    display: block;
    width: 100%;
    text-align: left;
    padding: 12px 14px;
    border-radius: 14px;
  
    background: rgba(255,255,255,.55);
    border: 1px solid var(--border);
  }

  /* Responsive */
  @media (max-width: 900px){
    .nav-desktop{ display: none; }
    .burger{ display: inline-flex; }
    .brand-name{ display: none; }
    .brand-logo{ width: 64px; height: auto; }

    .header-inner{
      padding: 20px 20px;
      gap: 12px;
    }

    .site-header .container{
      width: 100%;
      margin: 0;
    }

    .mobile-menu .container{
      width: 100%;
      margin: 0;
    }
  }
</style>