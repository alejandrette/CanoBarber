---
const links = [
  { href: "#precios", label: "Precios" },
  { href: "#galeria", label: "Galería" },
  { href: "#contacto", label: "Contacto" },
];
---

<header class="sticky top-0 z-50 bg-dark-bg/80 backdrop-blur-md border-b border-gold-primary/20">
  <div class="container-custom flex items-center justify-between py-4 gap-4">
    
    <a href="#" class="flex items-center gap-3 group">
      <img class="w-12 h-8 object-contain brightness-0 invert" src="/logo_black.png" alt="Logo Cano Barber" />
      <span class="hidden md:block font-titles text-xl font-bold tracking-tight group-hover:text-gold-primary transition-colors">
        Cano Barber
      </span>
      <span class="pill-custom ml-2">Don Benito</span>
    </a>

    <nav class="hidden md:flex items-center gap-4" aria-label="Navegación principal">
      {links.map((l) => (
        <a href={l.href} class="px-4 py-2 text-sm font-medium hover:text-gold-primary transition-colors uppercase tracking-widest">
          {l.label}
        </a>
      ))}
      <a class="btn btn-primary ml-4" href="#contacto text-xs">Reservar</a>
    </nav>

    <button
      id="burger-btn"
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 border border-white/10 rounded-lg bg-white/5"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="w-5 h-0.5 bg-gold-primary transition-all duration-300 transform origin-center"></span>
      <span class="w-5 h-0.5 bg-gold-primary transition-all duration-300"></span>
      <span class="w-5 h-0.5 bg-gold-primary transition-all duration-300 transform origin-center"></span>
    </button>
  </div>

  <div 
    id="mobile-menu" 
    class="fixed inset-x-0 top-[73px] hidden z-50 h-screen"
  >
    <div id="mobile-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    
    <nav class="relative mx-4 mt-4 p-6 bg-dark-bg border border-gold-primary/20 flex flex-col gap-4 shadow-2xl overflow-hidden">
      {links.map((l) => (
        <a href={l.href} class="mobile-link text-lg font-titles border-b border-white/5 pb-2 hover:text-gold-primary">
          {l.label}
        </a>
      ))}
      <a class="btn btn-primary mt-4 w-full" href="#contacto">Reservar Cita</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("burger-btn");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-backdrop");
  const spans = btn?.querySelectorAll("span");

  function toggleMenu() {
    const isOpen = btn?.getAttribute("aria-expanded") === "true";
    btn?.setAttribute("aria-expanded", String(!isOpen));
    menu?.classList.toggle("hidden");
    
    // Animación simple del icono burger
    if (spans) {
      if (!isOpen) {
        spans[0].classList.add("rotate-45", "translate-y-2");
        spans[1].classList.add("opacity-0");
        spans[2].classList.add("-rotate-45", "-translate-y-2");
      } else {
        spans[0].classList.remove("rotate-45", "translate-y-2");
        spans[1].classList.remove("opacity-0");
        spans[2].classList.remove("-rotate-45", "-translate-y-2");
      }
    }
  }

  btn?.addEventListener("click", toggleMenu);
  backdrop?.addEventListener("click", toggleMenu);

  // Cerrar al clickar un link
  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", toggleMenu);
  });
</script>