<section id="contacto">
    <div class="container">
      <h2 class="h2">Contacto</h2>
      <p class="lead">Rellena esto y te confirmamos por WhatsApp.</p>

      <div class="grid" style="grid-template-columns: 1fr 1fr; margin-top: 18px; align-items:start;">
        <form class="card" style="padding: 18px;" action="#" method="post">
          <div class="grid" style="grid-template-columns: 1fr; gap: 12px;">
            <label>
              <div class="muted" style="font-size: 13px; margin-bottom: 6px;">Nombre</div>
              <input name="nombre" required style="width:100%; padding:12px 12px; border-radius: 14px; border:1px solid rgba(255,255,255,.1); background: rgba(0,0,0,.25); color: var(--text);" />
            </label>

            <label>
              <div class="muted" style="font-size: 13px; margin-bottom: 6px;">Teléfono</div>
              <input name="telefono" required style="width:100%; padding:12px 12px; border-radius: 14px; border:1px solid rgba(255,255,255,.1); background: rgba(0,0,0,.25); color: var(--text);" />
            </label>

            <label>
              <div class="muted" style="font-size: 13px; margin-bottom: 6px;">Servicio</div>
              <select name="servicio" style="width:100%; padding:12px 12px; border-radius: 14px; border:1px solid rgba(255,255,255,.1); background: rgba(0,0,0,.25); color: var(--text);">
                <option>Corte</option>
                <option>Barba</option>
                <option>Corte + Barba</option>
              </select>
            </label>

            <label>
              <div class="muted" style="font-size: 13px; margin-bottom: 6px;">Mensaje</div>
              <textarea name="mensaje" rows="4" style="width:100%; padding:12px 12px; border-radius: 14px; border:1px solid rgba(255,255,255,.1); background: rgba(0,0,0,.25); color: var(--text);"></textarea>
            </label>

            <button class="btn primary" type="submit" style="cursor:pointer;">
              Enviar
            </button>
          </div>
        </form>

        <div class="card" style="padding: 18px;">
          <h3 style="margin:0 0 8px;">Datos rápidos</h3>
          <p class="muted" style="margin:0 0 14px;">
            📍 Avda Constitución N 49, Edificio Coliseo, Local 10, Don Benito<br/>
            📞 +34 657 77 43 15<br/>
            ✉️ hola@canobarber.com
          </p>

          <div class="divider"></div>

          <a class="btn" href="https://wa.me/34657774315" target="_blank" rel="noreferrer">
            Abrir WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>