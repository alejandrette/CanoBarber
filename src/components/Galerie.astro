---
const galeria = [
  {
    titulo: "Corte clásico",
    descripcion: "Cortes limpios adaptados a tu estilo.",
    imagen: "/photo1.jpg"
  },
  {
    titulo: "Arreglo de barba",
    descripcion: "Perfilado y diseño de barba con precisión.",
    imagen: "/photo2.jpg"
  },
  {
    titulo: "Corte moderno",
    descripcion: "Fade y estilos actuales para un look moderno.",
    imagen: "/photo3.jpg"
  },
  {
    titulo: "Color / Mechas",
    descripcion: "Mechas y color para dar personalidad a tu estilo.",
    imagen: "/photo4.jpg"
  }
];
---

<section id="galeria" class="section-padding">
  <div class="container-custom">
    <div class="card-custom">
      <h2 class="text-3xl md:text-4xl mb-8 flex items-center gap-3">
        <span class="w-10 h-px bg-gold-primary"></span> Galerida
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {galeria.map((item) => (
          <div class="relative group h-[420px] md:h-[350px] lg:h-[420px] overflow-hidden rounded-none border border-white/10">
            <img 
              src={item.imagen} 
              alt={item.titulo} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-dark-bg/20 to-transparent flex flex-col justify-end p-6">
              <h3 class="text-gold-primary font-titles text-xl mb-1 translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                {item.titulo}
              </h3>
              <p class="text-bone/80 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {item.descripcion}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>