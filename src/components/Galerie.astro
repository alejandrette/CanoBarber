<section id="galeria">
  <div class="container">
    <div class="galeria-box">
      <h2 class="h2">Galería</h2>

      <div class="galeria-grid">
        {Array.from({ length: 4 }).map(() => (
          <div class="card galeria-item"></div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
/* Caja exterior tipo precios */
.galeria-box{
  padding: 26px;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: var(--card);
  box-shadow: var(--shadow);
}

/* Grid */
.galeria-grid{
  display: grid;
  grid-template-columns: repeat(4, minmax(0,1fr));
  gap: 18px;
  margin-top: 18px;
}

/* Imagen */
.galeria-item{
  height: 440px;
  background: linear-gradient(
    135deg,
    rgba(245,193,75,.18),
    rgba(255,255,255,.03)
  );
  border: 1px solid rgba(255,255,255,.08);
}

/* 📱 Móvil */
@media (max-width: 900px){

  .galeria-grid{
    grid-template-columns: 1fr; /* 1 en 1 */
  }

  .galeria-item{
    height: 260px; /* más pequeñas en móvil */
  }

  .galeria-box{
    padding: 18px; /* un poco más compacto */
  }
}
</style>